2026-03-05 16:03:02 │ DEBUG   │ dune_client.api.base │ POST received input url=https://api.dune.com/api/v1/sql/execute, params={'sql': '\n-- New vs Returning Users per Day\nWITH first_seen AS (\n    SELECT\n        address,\n        MIN(first_time) AS first_time\n    FROM (\n        SELECT "from" AS address, MIN(evt_block_time) AS first_time\n        FROM erc20_bnb.evt_Transfer\n        WHERE contract_address = 0xe3ec133e29addfbba26a412c38ed5de37195156f\n        GROUP BY 1\n        UNION ALL\n        SELECT "to" AS address, MIN(evt_block_time) AS first_time\n        FROM erc20_bnb.evt_Transfer\n        WHERE contract_address = 0xe3ec133e29addfbba26a412c38ed5de37195156f\n        GROUP BY 1\n    )\n    GROUP BY 1\n),\ndaily_users AS (\n    SELECT evt_block_time, "from" AS address\n    FROM erc20_bnb.evt_Transfer\n    WHERE contract_address = 0xe3ec133e29addfbba26a412c38ed5de37195156f\n      AND evt_block_time >= NOW() - INTERVAL \'30\' DAY\n    UNION\n    SELECT evt_block_time, "to" AS address\n    FROM erc20_bnb.evt_Transfer\n    WHERE contract_address = 0xe3ec133e29addfbba26a412c38ed5de37195156f\n      AND evt_block_time >= NOW() - INTERVAL \'30\' DAY\n)\nSELECT\n    DATE_TRUNC(\'day\', d.evt_block_time) AS day,\n    COUNT(DISTINCT CASE\n        WHEN DATE_TRUNC(\'day\', f.first_time) = DATE_TRUNC(\'day\', d.evt_block_time)\n        THEN d.address\n    END) AS new_users,\n    COUNT(DISTINCT CASE\n        WHEN DATE_TRUNC(\'day\', f.first_time) < DATE_TRUNC(\'day\', d.evt_block_time)\n        THEN d.address\n    END) AS returning_users\nFROM daily_users d\nJOIN first_seen f ON d.address = f.address\nWHERE d.address != 0x0000000000000000000000000000000000000000\nGROUP BY 1\nORDER BY 1\n', 'performance': 'medium'}
