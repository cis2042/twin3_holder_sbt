2026-03-05 15:56:10 │ DEBUG   │ dune_client.api.base │ POST received input url=https://api.dune.com/api/v1/sql/execute, params={'sql': '\n-- Token Holder Distribution by Tier\n-- Analyzes ERC-20 Transfer events to compute current balances\nWITH transfers AS (\n    SELECT\n        "from" AS address,\n        -CAST(value AS DOUBLE) / 1e18 AS amount\n    FROM erc20_bnb.evt_Transfer\n    WHERE contract_address = {{token_address}}\n    UNION ALL\n    SELECT\n        "to" AS address,\n        CAST(value AS DOUBLE) / 1e18 AS amount\n    FROM erc20_bnb.evt_Transfer\n    WHERE contract_address = {{token_address}}\n),\nbalances AS (\n    SELECT\n        address,\n        SUM(amount) AS balance\n    FROM transfers\n    WHERE address != 0x0000000000000000000000000000000000000000\n    GROUP BY 1\n    HAVING SUM(amount) > 0\n)\nSELECT\n    CASE\n        WHEN balance >= 1000000 THEN \'whale\'\n        WHEN balance >= 100000  THEN \'large\'\n        WHEN balance >= 10000   THEN \'medium\'\n        WHEN balance >= 1000    THEN \'small\'\n        ELSE \'micro\'\n    END AS holder_tier,\n    COUNT(*) AS holder_count,\n    SUM(balance) AS total_balance,\n    AVG(balance) AS avg_balance,\n    MIN(balance) AS min_balance,\n    MAX(balance) AS max_balance\nFROM balances\nGROUP BY 1\nORDER BY total_balance DESC\n', 'performance': 'medium'}
